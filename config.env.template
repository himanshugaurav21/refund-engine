# =============================================================================
# Refund Engine - Configuration Template
# =============================================================================
# Copy this file to config.env and fill in your values:
#   cp config.env.template config.env
# Then source before running any scripts:
#   source config.env
# =============================================================================

# -- Databricks Workspace ---------------------------------------------------
export DATABRICKS_HOST="https://<workspace-id>.<cloud>.databricks.com"
export DATABRICKS_PROFILE="<your-cli-profile>"
export DATABRICKS_USER="<your-email>@databricks.com"

# -- SQL Warehouse -----------------------------------------------------------
export DATABRICKS_WAREHOUSE_ID="<warehouse-id>"

# -- Unity Catalog -----------------------------------------------------------
export REFUND_CATALOG="refund_decisioning"

# -- Foundation Model --------------------------------------------------------
export SERVING_ENDPOINT="databricks-claude-sonnet-4"

# -- Databricks App ----------------------------------------------------------
export APP_NAME="refund-console"
export APP_WORKSPACE_PATH="/Workspace/Users/${DATABRICKS_USER}/${APP_NAME}"

# -- Lakeflow Pipeline -------------------------------------------------------
export PIPELINE_NAME="refund-engine-pipeline"
export PIPELINE_TARGET_SCHEMA="refund_gold"
